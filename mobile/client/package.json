{
  "name": "maweja-client",
  "version": "1.0.0",
  "description": "MAWEJA Client App — Android + iOS | com.edcorp.maweja",
  "private": true,
  "scripts": {
    "build": "cd ../.. && VITE_MOBILE_MODE=client VITE_API_BASE_URL=https://maweja.net npx vite build --config vite.mobile.config.ts",
    "sync:android": "npx cap sync android",
    "sync:ios": "npx cap sync ios",
    "sync": "npx cap sync",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "add:android": "npx cap add android",
    "add:ios": "npx cap add ios"
  },
